# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Drive (서비스 계정 + DumpitRE 루트 폴더 공유)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-folder-id

# Google Gemini (RAG embedding + chat)
# text-embedding-004 는 Gemini API embedContent 불지원 → gemini-embedding-001 사용
GEMINI_API_KEY=your-gemini-api-key
# 404 나면 gemini-flash-latest / gemini-2.5-flash 등으로 변경
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# DB document_chunks.embedding = vector(768) 이면 768
GEMINI_EMBEDDING_DIMENSION=768

# Auth (코드에 비밀번호를 넣지 마세요. .env.local / Vercel에만 설정)
DUMPIT_ADMIN_PASSWORD=
DUMPIT_GUEST_PASSWORD=
DUMPIT_WRAP_PASSWORD=
